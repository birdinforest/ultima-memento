{
  "s.197a2a5fe19ebac6": "\u8d77\u521d\u53ea\u662f\u5c11\u6570\u4eba\u77e5\u6653\u3002\u90a3\u662f\u3010Black Knight\u3011\u5fc3\u5ff5\u6240\u53ec\u7684\u4e00\u573a\u5b9e\u9a8c\u3002\u4ed6\u9ebe\u4e0b\u9ad8\u9636\u6cd5\u5e08\u4e4b\u4e00\u3010Vordo\u3011\u8017\u8d39\u6570\u5e74\u5b8c\u5584\u6cd5\u672f\uff0c\u6700\u7ec8\u5c06\u3010Serpent Island\u3011\u9644\u8fd1\u7684\u5c0f\u5c9b\u3010Kuldar\u3011\u6574\u4e2a\u541e\u6ca1\u3002\u77f3\u50cf\u9b3c\u754f\u60e7\u3010Black Knight\u3011\u7684\u529b\u91cf\uff0c\u4ee5\u4e3a\u5c9b\u5c7f\u5df2\u6bc1\u3002\u771f\u76f8\u5374\u9634\u9669\u5f97\u591a\uff1a\u5c9b\u4ecd\u5728\u795e\u79d8\u4e4b\u74f6\u4e2d\uff0c\u6d6e\u5728\u627f\u8f7d\u540c\u88ab\u5e26\u6765\u7684\u751f\u547d\u7684\u6c34\u91cc\u3002\u3010Black Knight\u3011\u628a\u4e00\u4e9b\u56da\u5f92\u6d41\u653e\u5230\u74f6\u4e2d\uff0c\u5ea6\u8fc7\u4f59\u751f\u3002\u6570\u767e\u5e74\u8fc7\u53bb\uff0c\u56da\u5f92\u4eec\u57a6\u5730\u3001\u5efa\u57ce\u3001\u751f\u513f\u80b2\u5973\uff0c\u4e00\u5ea6\u5bcc\u8db3\u3002\u3010Vordo\u3011\u60f3\u5982\u3010Black Knight\u3011\u7edf\u6cbb\u9886\u5730\u90a3\u6837\u7edf\u6cbb\u6b64\u5730\uff0c\u4fbf\u8c0e\u79f0\u74f6\u5b50\u6bc1\u4e8e\u610f\u5916\uff1b\u3010Black Knight\u3011\u5df2\u65e0\u5fc3\u8fc7\u95ee\u3002\u3010Vordo\u3011\u628a\u57ce\u5821\u6295\u5165\u74f6\u4e2d\uff0c\u8f70\u7136\u843d\u5728\u57ce\u65c1\u3002\u4ed6\u4ee5\u6cd5\u672f\u8fdb\u5165\u74f6\u4e2d\uff0c\u53c8\u53ec\u5524\u6708\u95e8\uff0c\u4ee5\u4fbf\u65e5\u540e\u79bb\u53bb\u3002\u4ed6\u4ee5\u94c1\u8155\u7edf\u6cbb\u8fd1\u5341\u5e74\uff0c\u76f4\u5230\u6c11\u4f17\u8d77\u4e49\u7ec8\u7ed3\u5176\u66b4\u653f\u3002\u4ed6\u4eec\u5c01\u6b7b\u57ce\u5821\uff0c\u628a\u3010Vordo\u3011\u9020\u51fa\u7684\u6050\u6016\u5c3d\u6570\u9501\u5728\u91cc\u9762\u3002\u4f20\u8bf4\u4ed6\u7684\u9b3c\u9b42\u4ecd\u5728\u90a3\u4e9b\u5385\u5802\u6e38\u8361\uff0c\u624b\u91cc\u63e1\u7740\u80fd\u8ba9\u4ed6\u79bb\u5f00\u74f6\u5b50\u7684\u7b14\u8bb0\u3002\u82e5\u6211\u80fd\u5c06\u5176\u7075\u9b42\u6253\u5165\u771f\u6b7b\uff0c\u54ea\u6015\u53ea\u6709\u7247\u523b\uff0c\u4e5f\u8bb8\u5c31\u80fd\u593a\u4e0b\u7b14\u8bb0\uff0c\u7528 `gate` \u6216 `recall` \u9003\u79bb\u6b64\u5730\u3002",
  "s.19be93c4a70ed55e": "\u9690\u853d\u9677\u9631",
  "s.1ac778fdc217a7f4": "<BODY><BASEFONT Color=#b6d593>\u672c\u5730\u884c\u4f1a</BASEFONT></BODY>",
  "s.1c318349e3e27675": "\u7070\u9f20\u3010The Gray Mouser\u3011",
  "s.1c571ccfa4485f38": "\u4ece\u4e0b\u6c34\u9053\u53ef\u4ee5\u627e\u5230\u9003\u51fa\u865a\u7a7a\u7684\u8def\u3002",
  "s.1cef7596d683d7b6": "\u3010blackrock\u3011\u86c7\u5df2\u51e0\u4e4e\u5230\u624b\u3002\u6bcf\u4e00\u6761\u90fd\u4ee3\u8868\u5e73\u8861\u3001\u79e9\u5e8f\u4e0e\u6df7\u6c8c\u4e4b\u86c7\u3002\u82e5\u8981\u5236\u670d\u6df7\u6c8c\u4e0e\u79e9\u5e8f\u4e4b\u86c7\uff0c\u6211\u5fc5\u987b\u96c6\u9f50\u8fd9\u4e09\u4ef6\u7269\u54c1\u3002\u6211\u5728\u3010Lord British\u3011\u7684\u56fe\u4e66\u9986\u91cc\u627e\u5230\u4e00\u5377\u53e4\u8f74\uff0c\u7ed9\u4e86\u6211\u6025\u9700\u7684\u7ebf\u7d22\u3002\u9986\u5458\u628a\u5b83\u5f52\u4e3a\u4f20\u8bf4\uff0c\u6211\u5374\u76f8\u4fe1\u90a3\u662f\u771f\u7684\u3002\u6211\u987b\u627e\u5230\u3010Serpent Sanctum\u3011\u4e2d\u7684\u3010Wall of Lights\u3011\u3002\u9760\u8fd1\u5b83\u65f6\uff0c\u6211\u4f1a\u540c\u65f6\u51fa\u73b0\u5728\u73b0\u4e16\u4e0e\u865a\u7a7a\u4ea4\u53e0\u7684\u623f\u95f4\u3002\u6211\u5fc5\u987b\u8d70\u8fd1\u79e9\u5e8f\u4e0e\u6df7\u6c8c\u7684\u96d5\u50cf\uff0c\u5ba3\u544a\u6211\u662f\u6765\u6062\u590d\u5e73\u8861\u7684\u3002\u90a3\u6837\u5e94\u80fd\u8ba9\u5176\u4e2d\u4e00\u6761\u3010blackrock\u3011\u86c7\u83b7\u5f97\u5e73\u8861\u4e4b\u86c7\u7684\u529b\u91cf\u3002\u7136\u540e\u6211\u82e5\u89e6\u78b0\u6bcf\u5ea7\u96d5\u50cf\uff0c\u86c7\u5c31\u4f1a\u5728\u6b64\u754c\u73b0\u8eab\uff0c\u6211\u624d\u80fd\u5236\u670d\u5b83\u3002\u4e24\u6761\u86c7\u90fd\u5fc5\u987b\u5982\u6b64\uff0c\u56e0\u4e3a\u4ed6\u4eec\u90fd\u8981\u88ab\u5236\u670d\u3002\u4e00\u65e6\u5b83\u4eec\u7684\u3010blackrock\u3011\u5f62\u4f53\u4e0e\u88ab\u5236\u7684\u7075\u9b42\u4e3a\u6211\u6240\u6536\uff0c\u6211\u5c31\u80fd\u5bfb\u627e\u3010Great Earth Serpent\u3011\uff0c\u5411\u5b83\u5ba3\u544a\u6211\u5df2\u7ef4\u6301\u5e73\u8861\u3002\u6211\u73b0\u5728\u8981\u53bb\u9762\u5bf9\u3010Bane of Insanity\u3011\uff0c\u56e0\u4e3a\u6211\u5df2\u627e\u5230\u3010Orb of Logic\u3011\u3002\u82e5\u6211\u80fd\u4ece\u63a5\u4e0b\u6765\u7684\u6218\u6597\u4e2d\u6d3b\u4e0b\u6765\uff0c\u518d\u53bb\u627e\u53e6\u5916\u4e24\u4ef6\u3002",
  "s.1d3bd775415ce614": "\u5c9b\u5c7f\u7684\u8bc5\u5492",
  "s.1e33040ea2bcfe34": "\u9a91\u58eb\u9053\u662f\u5d07\u9ad8\u5fd7\u4e1a\uff0c\u4e3a\u9ed1\u6697\u4e4b\u5730\u5e26\u6765\u5149\u660e\u3002\u672a\u77e5\u7684\u90aa\u6076\u6a2a\u884c\uff0c\u9a91\u58eb\u6b63\u662f\u6211\u4eec\u4eca\u65e5\u548c\u5e73\u7684\u5b88\u62a4\u8005\u3002\u9a91\u58eb\u7684\u529b\u91cf\u5f80\u5f80\u6765\u81ea\u6177\u6168\uff1a\u4ed6\u4eec\u6d88\u706d\u90aa\u6076\u65f6\u5e38\u89c1\u8d22\u5b9d\u8fc7\u591a\uff0c\u4fbf\u53d6\u4e00\u90e8\u5206\u7559\u5728\u795e\u6bbf\u3001\u796d\u575b\u6216\u5973\u795e\u50cf\u524d\uff0c\u7531\u795e\u804c\u4eba\u5458\u6536\u96c6\u540e\u5206\u7ed9\u8d2b\u5f31\u3002\u6709\u4e00\u540d\u9a91\u58eb\u4e0d\u4fe1\u8fd9\u5957\u3002\u4ed6\u8d2a\u6c42\u4e00\u5207\u8d22\u5bcc\uff0c\u5e38\u4e3a\u593a\u8d22\u6740\u4eba\u3002\u4ed6\u7684\u7075\u9b42\u8150\u5316\u81f3\u6b64\uff0c\u9a91\u58eb\u4e4b\u529b\u6e10\u6e10\u53d8\u9ed1\u3001\u626d\u66f2\uff0c\u5316\u4e3a\u6076\u81ed\u7684\u90aa\u6076\u3002\u4ed6\u62ab\u4e0a\u9ed1\u7532\uff0c\u52ab\u63a0\u6751\u9547\u4e0e\u57ce\u5e02\u3002\u9a91\u58eb\u5949\u547d\u94f2\u9664\u8fd9\u80cc\u4fe1\u8005\uff0c\u5374\u591a\u6709\u9635\u4ea1\u3002\u3010Lord British\u3011\u96c6\u7ed3\u5927\u519b\uff0c\u7531\u9ebe\u4e0b\u6700\u5f3a\u9a91\u58eb\u7387\u9886\uff0c\u4e00\u8def\u8ffd\u5230\u795e\u79d8\u7684\u3010Umber Veil\u3011\u5c9b\u3002\u5927\u519b\u62b5\u8fbe\u65f6\uff0c\u3010Renika\u3011\u6751\u6b63\u70c8\u706b\u718a\u718a\u3002\u5e78\u5b58\u8005\u6709\u7684\u8eb2\u5728\u9644\u8fd1\u6559\u5802\uff0c\u6709\u7684\u9501\u8fdb\u5c71\u5821\u3002\u4ed6\u4eec\u8bf4\u9ed1\u9a91\u58eb\u9003\u5f80\u3010Serpent Island\u3011\u3002\u5927\u519b\u653e\u5f03\u8ffd\u51fb\uff0c\u56e0\u4e3a\u9ed1\u9a91\u58eb\u5df2\u4e0d\u518d\u5a01\u80c1\u4ed6\u4eec\u7684\u571f\u5730\u3002\u4ed6\u4eec\u5e2e\u52a9\u3010Renika\u3011\u91cd\u5efa\uff0c\u7136\u540e\u8fd4\u56de\u6545\u571f\u3002\u90a3\u662f\u5f88\u4e45\u4ee5\u524d\u7684\u4e8b\u4e86\u3002\u6b64\u540e\u65e0\u4eba\u518d\u5728\u3010Sosaria\u3011\u89c1\u8fc7\u90a3\u4f4d\u9ed1\u9a91\u58eb\u3002\u9152\u9986\u91cc\u591a\u5e74\u6d41\u8a00\u4e0d\u7edd\uff1a\u6709\u4eba\u81ea\u79f0\u822a\u81f3\u3010Serpent Island\u3011\uff0c\u53d1\u73b0\u9ed1\u9a91\u58eb\u7b51\u5792\u7684\u5c0f\u5c9b\uff1b\u751a\u81f3\u6709\u4eba\u8bf4\u89c1\u8fc7\u6700\u5927\u7684\u5730\u4e0b\u91d1\u5e93\u3002\u636e\u8bf4\u4ed6\u6bd5\u751f\u6240\u593a\u7686\u85cf\u5176\u4e2d\uff0c\u7531\u5b88\u536b\u770b\u7ba1\u3002\u6211\u89c9\u5f97\u8fd9\u4e9b\u6545\u4e8b\u5938\u5927\u5176\u8bcd\uff0c\u8bb2\u6545\u4e8b\u7684\u4eba\u53c8\u62ff\u4e0d\u51fa\u91d1\u5e93\u7684\u8bc1\u636e\u3002\u6211\u4eec\u53ea\u8be5\u5e86\u5e78\u4ed6\u5df2\u6c38\u8fdc\u6d88\u5931\u3002",
  "s.1ed09454f8174656": "\u4f60\u5f53\u524d\u7684\u4e0a\u9650\u5fc5\u987b\u8fbe\u5230 {0} \u624d\u80fd\u4f7f\u7528\u6b64\u5377\u8f74",
  "s.1fe56dacffdf692f": "\u6cd5\u5e08\u3010Zuri\u3011",
  "s.205f3505ce5b555e": "\u6211\u5531\u7684\u8fd9\u66f2\u8bb2\u8ff0\u4e00\u4e2a\u5bd2\u51b7\u51ac\u65e5\uff1a\u57ce\u5821\u9ad8\u5899\u3001\u706b\u628a\u5927\u5385\uff0c\u4ee5\u53ca\u4eba\u4eec\u4ed8\u51fa\u7684\u4ee3\u4ef7\u3002\u90aa\u6076\u9041\u53bb\u3001\u52c7\u8005\u6d41\u8840\uff0c\u9ed1\u6697\u8005\u5374\u7559\u4e0b\u3002\u53e4\u4eba\u4e3a\u4e86\u8840\u4e0e\u91d1\uff0c\u7ec8\u5c06\u62ef\u6551\u3010Skara Brae\u3011\u3002",
  "s.22b81a2dd4c18d3a": "\u3010Asajj Ventress\u3011\uff0c\u3010Syth\u3011\u5c0a\u4e3b",
  "s.22d47eebd40ca538": "\u6c34\u6676\u96d5\u50cf\u65e0\u6cd5\u6467\u6bc1\u3002",
  "s.22ff7aaaadd66a1c": "\u6709\u4eba\u89c1\u8fc7\u4e00\u4f4d\u6cd5\u5e08\u8d70\u8fdb\u5730\u4e0b\u57ce\u7684\u7262\u623f\uff0c\u7136\u540e\u6d88\u5931\u4e0d\u89c1\u3002",
  "s.2304e5bf9096f564": "<div align=\"right\" color=\"2100\">",
  "s.23bf7ab37f661d92": "<BODY><BASEFONT Color=#b6d593>\u8fd9\u7247\u571f\u5730\u4e0a\u8bb8\u591a\u56e2\u4f53\u5efa\u7acb\u4e86\u884c\u4f1a\u9986\u820d\uff0c\u5e38\u5728\u62db\u52df\u6210\u5458\u3002\u8fd9\u4e9b\u884c\u4f1a\u4e0e\u5192\u9669\u8005\u81ea\u884c\u7ec4\u5efa\u7684\u5404\u7c7b\u884c\u4f1a\u5f7c\u6b64\u72ec\u7acb\uff0c\u524d\u8005\u805a\u7126\u5177\u5907\u7279\u5b9a\u6280\u827a\u4e0e\u884c\u5f53\u7684\u4eba\u7fa4\u3002\u4ee5\u4e0b\u662f\u6b63\u5728\u62db\u52df\u6210\u5458\u7684\u884c\u4f1a\u9986\u5217\u8868\u3002<br><br>- \u70bc\u91d1\u672f\u58eb\u884c\u4f1a<br>- \u5f13\u7bad\u624b\u884c\u4f1a<br>- \u523a\u5ba2\u884c\u4f1a<br>- \u541f\u6e38\u8bd7\u4eba\u884c\u4f1a<br>- \u9ed1\u9b54\u6cd5\u884c\u4f1a<br>- \u94c1\u5320\u884c\u4f1a<br>- \u6728\u5320\u884c\u4f1a<br>- \u5236\u56fe\u5e08\u884c\u4f1a<br>- \u70f9\u996a\u884c\u4f1a<br>- \u5fb7\u9c81\u4f0a\u884c\u4f1a<br>- \u5143\u7d20\u4f7f\u884c\u4f1a<br>- \u6cbb\u7597\u5e08\u884c\u4f1a<br>- \u56fe\u4e66\u7ba1\u7406\u5458\u884c\u4f1a<br>- \u6cd5\u5e08\u884c\u4f1a<br>- \u6c34\u624b\u884c\u4f1a<br>- \u5546\u4eba\u884c\u4f1a<br>- \u77ff\u5de5\u884c\u4f1a<br>- \u6e38\u4fa0\u884c\u4f1a<br>- \u88c1\u7f1d\u884c\u4f1a<br>- \u76d7\u8d3c\u884c\u4f1a<br>- \u4fee\u8865\u5320\u884c\u4f1a<br>- \u6218\u58eb\u884c\u4f1a<br><br>\u52a0\u5165\u4ee5\u4e0a\u4efb\u4e00\u884c\u7684\u6761\u4ef6\uff08\u6b64\u5916\u4e0d\u5f97\u5df2\u662f\u53e6\u4e00\u5bb6\u672c\u5730\u884c\u4f1a\u6210\u5458\uff09\u662f ",
  "s.266b6ba2bb356d86": "\u636e\u8bf4\u6211\u4eec\u6559\u56e2\u7684\u7b2c\u4e00\u4eba\uff0c\u4fbf\u662f\u4ed6\u4eec\u7684\u7b2c\u4e00\u4eba\u3002\u57ce\u5821\u5728\u6570\u4e16\u7eaa\u524d\u4ece\u5929\u800c\u964d\uff0c\u5899\u57a3\u4e4b\u5185\u5e26\u6765\u4e86\u6240\u8c13\u3010Syth\u3011\u7684\u707e\u6b83\u3002\u591a\u6570\u4eba\u53ea\u5f53\u90a3\u662f\u4f20\u8bf4\u6216\u7ae5\u8bdd\uff0c\u56e0\u4e3a\u4ed6\u4eec\u6781\u5c11\u73b0\u8eab\uff0c\u800c\u89c1\u8fc7\u4ed6\u4eec\u7684\u4eba\uff0c\u5f80\u5f80\u5728\u6700\u540e\u65f6\u523b\u5bf9\u4e0a\u3010Syth\u3011\u7684\u53cc\u773c\u3002\u4ed6\u4eec\u7684\u52a8\u673a\u6781\u5176\u90aa\u6076\uff0c\u6216\u8bb8\u53ef\u4e0e\u6076\u9b54\u7684\u76ee\u6807\u76f8\u6bd4\u3002\u4ed6\u4eec\u53ea\u60f3\u5728\u592a\u5e73\u4e4b\u5730\u5236\u9020\u6df7\u6c8c\uff0c\u5e76\u4ece\u9634\u5f71\u4e2d\u7edf\u6cbb\u4f17\u751f\u3002\u4ed6\u4eec\u65a9\u6740\u6321\u8def\u8005\uff0c\u593a\u53d6\u6240\u6b32\u4ee5\u9042\u5176\u76ee\u7684\u3002\u4ed6\u4eec\u7cbe\u901a\u9b54\u6cd5\u4e0e\u5200\u5251\uff0c\u4f46\u53e4\u4ee3\u6559\u8bf2\u8bf4\u4ed6\u4eec\u7684\u529b\u91cf\u6765\u81ea\u5fc3\u667a\uff0c\u800c\u975e\u6cd5\u5e08\u7684\u5492\u672f\u3002\u51e1\u8bfb\u6b64\u4e66\u8005\u52a1\u5fc5\u8b66\u60d5\u3002\u3010Syth\u3011\u786e\u6709\u5176\u4e8b\uff0c\u613f\u4f60\u6c38\u4e0d\u5728\u6218\u573a\u4e0a\u4e0e\u4e4b\u4e3a\u654c\u3002",
  "s.26de0d021e403515": "\u3010Mondain\u3011\u7684\u6545\u4e8b",
  "s.283d878452e8c5f4": "\u5e73\u8861 \u5377\u4e00\uff08\u5171\u4e8c\u5377\uff09",
  "s.2a1806a944bea722": "\u4eba\u7c7b\u4e4b\u5730\u7684\u6e38\u4fa0\u5c06\u9ed1\u6697\u7cbe\u7075\u4e00\u8def\u8ffd\u56de\u8001\u5bb6\u3002\u4ed6\u4eec\u4ee5\u4e3a\u3010Lodoria\u3011\u7684\u4e16\u754c\u5df2\u88ab\u8fd9\u4e9b\u90aa\u5996\u7cbe\u73b7\u6c61\uff0c\u4fbf\u7acb\u5fd7\u9664\u5c3d\u4ed6\u4eec\u3002\u7ecf\u591a\u4e2a\u6708\u4eae\u7684\u72e9\u730e\uff0c\u4ed6\u4eec\u4e0e\u5730\u8868\u7cbe\u7075\u76f8\u9047\uff0c\u540e\u8005\u6bd4\u6e38\u4fa0\u6240\u719f\u6089\u7684\u8981\u6e29\u548c\u5f97\u591a\u3002\u6e38\u4fa0\u4e0e\u3010Lodoria\u3011\u7cbe\u7075\u7684\u540c\u76df\u7531\u6b64\u5f00\u59cb\uff0c\u6e05\u9664\u90aa\u6076\u6210\u4e86\u5730\u4e0a\u4e0e\u5730\u4e0b\u540c\u65f6\u8fdb\u884c\u7684\u9759\u6218\u3002\u6e38\u4fa0\u5728\u3010City of Lodoria\u3011\u9644\u8fd1\u5c71\u4e2d\u7b51\u5821\uff0c\u4f3c\u4e4e\u53ea\u80fd\u901a\u8fc7\u9ed1\u5982\u6697\u7cbe\u7075\u80a4\u8272\u7684\u6d1e\u7a74\u62b5\u8fbe\u3002\u5916\u4eba\u5165\u5185\u5fc5\u8ff7\uff0c\u4f46\u4ece\u6e38\u4fa0\u54e8\u7ad9\u4e0b\u6765\u7684\u4eba\u5374\u80fd\u8ba4\u8def\u5f80\u8fd4\u3002\u867d\u7136\u5fb7\u9c81\u4f0a\u66fe\u4ee5\u6cd5\u672f\u628a\u6e38\u4fa0\u9001\u4e0a\u5c71\u9876\uff0c\u4f20\u8bf4\u5374\u6709\u4e00\u5ea7\u540d\u5524\u3010Undermountain\u3011\u7684\u5927\u5385\u4e45\u5df2\u5c01\u95ed\u5e9f\u5f03\u3002\u82e5\u80fd\u627e\u5230\u901a\u5f80\u3010Undermountain\u3011\u7684\u8def\uff0c\u6211\u4e5f\u8bb8\u5c31\u5728\u6e38\u4fa0\u54e8\u7ad9\u6b63\u4e0b\u65b9\u3002\u6211\u8981\u4ece\u8425\u5730\u4ee5\u5317\u3001\u8725\u8734\u4e0e\u86c7\u6210\u707e\u7684\u90a3\u4e2a\u6d1e\u7a74\u5f00\u59cb\u641c\u5bfb\u3002",
  "s.2cd67f65f9f668ed": "\u7a83\u53d6\u5f80\u6614",
  "s.2dc8e97407ce8e39": "\u6536\u85cf\u5bb6\u3010Daran\u3011",
  "s.2e49df4167a033ce": "\u5f2f\u6298\u94a2\u94c1\u7684\u5de5\u827a\u5df2\u6d41\u4f20\u6570\u4e16\u7eaa\uff0c\u4f46\u5728\u4eba\u7c7b\u5174\u8d77\u4e4b\u524d\u2026\u2026\u6709\u4eba\u4ee5\u706b\u5c71\u4e4b\u706b\u953b\u9020\u3002\u3010Purslos\u3011\u636e\u8bf4\u662f\u77f3\u50cf\u9b3c\uff0c\u4e5f\u662f\u5353\u7edd\u5de5\u5320\uff0c\u4e0d\u4ec5\u80fd\u8ba9\u94a2\u94c1\u968f\u5fc3\u6210\u5f62\uff0c\u8fd8\u80fd\u4ee5\u5c9b\u4e0a\u7194\u5ca9\u4e4b\u529b\u5f3a\u5316\u5b83\u3002\u4f20\u8bf4\u3010Purslos\u3011\u4e3a\u5176\u4e3b\u3010Tuxluka\u3011\u94f8\u5251\uff0c\u5251\u5982\u70c8\u706b\uff0c\u707c\u70e7\u4e0e\u5207\u5272\u540c\u6837\u81f4\u547d\u3002\u3010Tuxluka\u3011\u4ee5\u6b64\u5315\u9996\u8d62\u5f97\u3010Ophidian\u3011\u6218\u4e89\uff0c\u4e3a\u3010Serpent Island\u3011\u5e26\u6765\u548c\u5e73\u3002\u4e5f\u8bb8\u6709\u4e00\u5929\u6211\u4eec\u80fd\u5b66\u4f1a\u8fd9\u79cd\u953b\u9020\u79d8\u6cd5\u3002\u65e0\u8bba\u5bd3\u8a00\u6216\u53f2\u5b9e\uff0c\u6545\u4e8b\u4e4b\u591a\u90fd\u4e0d\u5bb9\u5ffd\u89c6\u3002",
  "s.2ef275e799c25d28": "\u75af\u72c2\u4e4b\u795e\u7684\u4e00\u5c0a\u96d5\u50cf\u7acb\u5728\u3010Harkyn\u3011\u9ad8\u5854\u4e4b\u5dc5\u3002",
  "s.2f32dc8852ebcd0a": "\u76f8\u4f20\u5f88\u4e45\u4ee5\u524d\uff0c\u3010Sosaria\u3011\u5904\u4e8e\u9ec4\u91d1\u65f6\u4ee3\uff1a\u5b89\u5b81\u904d\u5e03\u5927\u5730\uff0c\u996e\u98df\u4e30\u8db3\uff0c\u4eba\u4e0e\u517d\u548c\u7766\uff0c\u91d1\u94f6\u5145\u76c8\u3002\u3010Mondain\u3011\u662f\u53e4\u738b\u3010Wolfgang\u3011\u7684\u6b21\u5b50\uff0c\u89ca\u89ce\u5144\u957f\u7684\u7ee7\u627f\u6743\uff0c\u4fbf\u4ee5\u5f3a\u5927\u529b\u91cf\u884c\u6076\u3002\u591a\u5e74\u95f4\u4ed6\u8d70\u904d\u3010Sosaria\u3011\uff0c\u6240\u8fc7\u4e4b\u5904\u5c3d\u662f\u90aa\u6076\u4e0e\u6b7b\u4ea1\u3002\u4ed6\u5f00\u51ff\u6781\u6df1\u7684\u5730\u4e0b\u57ce\uff0c\u6df1\u5e7f\u5230\u6700\u5e95\u5c42\u4ece\u672a\u6709\u4eba\u63a2\u5c3d\uff1b\u53c8\u5728\u5176\u4e2d\u91ca\u653e\u66f4\u591a\u90aa\u6076\uff1a\u8868\u5c42\u9644\u8fd1\u662f\u76d7\u8d3c\u3001\u9ab7\u9ac5\u4e0e\u86c7\uff0c\u6df1\u5904\u5219\u7531\u6076\u9b54\u4e0e\u708e\u9b54\u770b\u5b88\u3002\u3010Sosaria\u3011\u8840\u6d41\u6210\u6cb3\uff0c\u79fd\u7269\u5f88\u5feb\u903c\u8fd1\u5730\u8868\u3002\u3010Mondain\u3011\u964d\u4e0b\u75be\u75c5\u4e0e\u761f\u75ab\uff0c\u4eba\u755c\u7686\u6d3b\u5728\u6050\u60e7\u4e2d\uff0c\u90a3\u4fbf\u662f\u9ed1\u6697\u65f6\u4ee3\u3002\u540e\u6765\u5730\u4e0a\u51fa\u73b0\u4e00\u4f4d\u7eaf\u6d01\u6b63\u76f4\u4e4b\u4eba\uff0c\u4e0e\u9ed1\u6697\u541b\u738b\u4ea4\u6218\u3002\u3010British\u3011\uff0c\u767d\u5149\u52c7\u58eb\uff0c\u5728\u5730\u4e0b\u57ce\u8ff7\u5bab\u6df1\u5904\u4e0e\u3010Mondain\u3011\u51b3\u6218\uff0c\u7ec8\u5c06\u3010Mondain\u3011\u9010\u51fa\u3010Sosaria\u3011\u3002\u3010British\u3011\u83b7\u79f0\u3010Lord British\u3011\uff0c\u3010Sosaria\u3011\u7684\u5b88\u62a4\u8005\u3002\u7136\u800c\u5927\u5730\u5df2\u53d7\u91cd\u521b\uff0c\u3010Sosaria\u3011\u7684\u590d\u5174\u81ea\u6b64\u5f00\u59cb\u3002"
}
