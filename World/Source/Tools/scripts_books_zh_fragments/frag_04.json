 \u6301\u7eed\u7ea6 2 \u81f3 13 \u5206\u949f<br><br>- \u4fee\u8865\u7075\u836f<br>    \u6301\u7eed\u7ea6 2 \u81f3 13 \u5206\u949f<br><br>- \u8ffd\u8e2a\u7075\u836f<br>    \u6301\u7eed\u7ea6 2 \u81f3 13 \u5206\u949f<br><br>- \u517d\u533b\u7075\u836f<br>    \u6301\u7eed\u7ea6 1 \u81f3 6 \u5206\u949f",
  "s.59780b3b7109e563": "\u3010Akalabeth\u3011\u8bb0\u4e8b",
  "s.59d5195a3243bdaf": "\u901a\u7f09\uff01",
  "s.5b3a19605cf65b9c": "\u7fa4\u5c9b\u7684\u3010Dreova\u3011",
  "s.5b8af0bba2dd49b5": "\u6709\u4eba\u8bf4\u5b83\u6765\u81ea\u672a\u6765\uff1a\u66f4\u50cf\u6076\u9b54\u800c\u975e\u91d1\u5c5e\u7684\u673a\u5668\u3002\u3010Exodus\u3011\u662f\u3010Sosaria\u3011\u7684\u7978\u60a3\uff0c\u7531\u3010Mondain\u3011\u4e0e\u3010Minax\u3011\u4e4b\u624b\u6240\u9020\u3002\u5f53\u3010Stranger\u3011\u6bc1\u6389\u3010Exodus\u3011\u7684\u673a\u68b0\u8eaf\u58f3\u540e\uff0c\u86f0\u4f0f\u5176\u4e0b\u7684\u6076\u9b54\u81ea\u52a8\u673a\u88ab\u91ca\u653e\u3002\u5b83\u4f9d\u7a0b\u5e8f\u5728\u5404\u5730\u8fc1\u5f99\uff0c\u4ece\u4e0d\u4e45\u7559\u3002\u5b83\u524d\u5f80\u5893\u7a74\u4e0e\u5730\u4e0b\u57ce\uff0c\u8bb0\u5f55\u6240\u89c1\u9b54\u7269\uff0c\u5b66\u4e60\u6210\u4e3a\u66f4\u81f4\u547d\u7684\u5bf9\u624b\u2014\u2014\u6700\u8fd1\u5b83\u77ac\u95f4\u6740\u4e86\u6211\u7684\u7070\u718a\u540c\u4f34\u3002\u5b83\u6709\u80fd\u5728\u9b54\u6cd5\u4e0e\u8fd1\u6218\u9632\u62a4\u4e4b\u95f4\u5207\u6362\u7684\u529b\u573a\uff0c\u4e5f\u653e\u5c04\u7535\u51fb\u7075\u9b42\u7684\u675f\u6d41\u3002\u4e3a\u4f55\u8981\u9762\u5bf9\u8fd9\u79cd\u5b58\u5728\uff1f\u6211\u8981\u7684\u662f\u9ed1\u6697\u6838\u5fc3\u3002\u5728\u8fd9\u91d1\u5c5e\u6076\u9b54\u7684\u80f8\u8154\u91cc\uff0c\u3010Exodus\u3011\u6709\u4e00\u9897\u6838\u5fc3\uff0c\u50a8\u5b58\u5b83\u5b66\u5230\u7684\u4e00\u5207\u3002\u6211\u8981\u7684\u4e0d\u662f\u91cc\u9762\u7684\u8d44\u8baf\uff0c\u800c\u662f\u6467\u6bc1\u6838\u5fc3\u4ee5\u91ca\u653e\u5176\u529b\u91cf\u3002\u6211\u5df2\u627e\u5230\u3010Savaged Empire\u3011\u4e2d\u7684\u53e4\u8001\u77f3\u50cf\u9b3c\u57ce\uff0c\u5374\u5c1a\u672a\u627e\u5230\u5176\u4e2d\u7684\u3010Forge of Virtue\u3011\uff0c\u5fc5\u987b\u628a\u6838\u5fc3\u6295\u5165\u5176\u4e2d\u3002\u82e5\u77f3\u50cf\u9b3c\u6240\u8a00\u4e0d\u865a\uff0c\u628a\u7269\u54c1\u653e\u5728\u3010Shrine of Diligence\u3011\u4e0a\uff0c\u4fbf\u80fd\u5728\u6838\u5fc3\u88ab\u6bc1\u65f6\u5438\u6536\u5176\u529b\u91cf\u3002\u6211\u8fd8\u987b\u5ff5\u8bf5\u5492\u8bed `Vas An Ort Ailem`\uff0c\u628a\u6838\u5fc3\u63b7\u5165\u7194\u7089\u3002\u796d\u575b\u636e\u8bf4\u5c31\u5728\u7194\u7089\u65c1\uff0c\u4f46\u82e5\u627e\u4e0d\u5230\u3010Exodus\u3011\u4e0b\u4e00\u6b21\u73b0\u8eab\u4e4b\u5904\uff0c\u4e00\u5207\u4e5f\u65e0\u7528\u3002\u4e16\u754c\u5982\u6b64\u8fbd\u9614\uff0c\u8ffd\u8e2a\u5b83\u6781\u4e3a\u8270\u96be\uff0c\u65f6\u95f4\u7d27\u8feb\u3002\u5373\u4fbf\u6211\u62ff\u5230\u9ed1\u6697\u6838\u5fc3\uff0c\u65f6\u95f4\u4e5f\u6781\u6709\u9650\u2014\u2014\u3010Exodus\u3011\u4f1a\u91cd\u5efa\u81ea\u8eab\uff0c\u6838\u5fc3\u4e5f\u4f1a\u56de\u5230\u5b83\u80f8\u8154\u3002\u6211\u4e0d\u77e5\u9053\u662f\u5426\u6709\u4ec0\u4e48\u80fd\u6bc1\u6389\u8fd9\u5730\u72f1\u673a\u5668\u3002",
  "s.5bb27fb86c807b2f": "\u4e00\u5c01\u4fe1",
  "s.5bbb5c183188fe8e": "\u6b64\u9b54\u6cd5\u53ea\u80fd\u5728\u3010Shrine of Dexterity\u3011\u91ca\u653e\u3002"
}
