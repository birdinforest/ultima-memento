{
  "s.4920bbf900d37656": "\u4e00\u5207\u59cb\u4e8e\u3010Batlin\u3011\uff0c\u4e00\u4f4d\u6cd5\u529b\u9ad8\u5f3a\u7684\u5fb7\u9c81\u4f0a\u3002\u4ed6\u751f\u4e8e\u3010Yew\u3011\uff0c\u5728\u5fb7\u9c81\u4f0a\u4e2d\u957f\u5927\u3002\u6210\u5e74\u540e\u6e38\u5386\u56db\u65b9\uff0c\u671f\u95f4\u7ed3\u8bc6\u3010Elizabeth\u3011\u4e0e\u3010Abraham\u3011\u3002\u4ed6\u4e5f\u66fe\u5230\u3010Skara Brae\u3011\uff0c\u5411\u3010Mangar\u3011\u8ffd\u95ee\u751f\u6b7b\u7684\u7b54\u6848\u3002\u3010Batlin\u3011\u5f97\u77e5\u5e76\u65e0\u7b54\u6848\u540e\uff0c\u9ed1\u6697\u4fbf\u5728\u4ed6\u5fc3\u4e2d\u6ecb\u957f\u3002\u4e0d\u4e45\u3010Guardian\u3011\u4e0e\u4ed6\u63a5\u89e6\uff0c\u4ed6\u4e0e\u3010Elizabeth\u3011\u3001\u3010Abraham\u3011\u4e3a\u6e34\u6c42\u529b\u91cf\u800c\u521b\u7acb\u3010Fellowship\u3011\uff0c\u597d\u8ba9\u3010Guardian\u3011\u593a\u53d6\u3010Sosaria\u3011\u3002\u90a3\u90aa\u6076\u56fe\u8c0b\u5931\u8d25\u540e\uff0c\u3010Batlin\u3011\u5076\u7136\u542c\u89c1\u5927\u6cd5\u5e08\u3010Zekylis\u3011\u8c08\u8d77\u3010Serpent Island\u3011\u3002\u3010Guardian\u3011\u547d\u3010Batlin\u3011\u524d\u5f80\u8be5\u5c9b\uff0c\u53bb\u6355\u83b7\u540d\u4e3a\u3010Chaos\u3011\u4e4b\u3010Banes\u3011\u7684\u7cbe\u534e\uff0c\u597d\u8ba9\u3010Guardian\u3011\u91ca\u4e8e\u3010Sosaria\u3011\u3002\u3010Batlin\u3011\u672c\u6b32\u501f\u3010Banes\u3011\u593a\u6743\uff0c\u5374\u51fa\u4e86\u5dee\u9519\uff0c\u5b83\u4eec\u8131\u79bb\u9b54\u6cd5\u56da\u7b3c\uff0c\u9644\u5728\u3010Batlin\u3011\u4e09\u540d\u8ffd\u968f\u8005\u8eab\u4e0a\uff0c\u6740\u4e86\u3010Batlin\u3011\uff0c\u9003\u5f80\u3010Serpent Island\u3011\u5404\u81ea\u7684\u53bb\u5904\u3002\u540e\u679c\u6df1\u8fdc\uff1a\u6709\u4e9b\u751f\u7269\u56e0\u3010Banes\u3011\u5f71\u54cd\u800c\u53d7\u8bc5\u3002\u5192\u9669\u8005\u8c08\u8d77\u8fd9\u4e9b\u53d7\u8bc5\u9b54\u7269\uff0c\u8bf4\u5b83\u4eec\u4e00\u65e6\u53d7\u8bc5\u4fbf\u66f4\u5f3a\u608d\u3002\u8bb8\u591a\u4eba\u6b7b\u5728\u8fd9\u4e9b\u91ce\u517d\u624b\u4e0b\uff0c\u4f46\u51fb\u8d25\u5b83\u4eec\u7684\u4eba\u6709\u65f6\u5e26\u56de\u96be\u4ee5\u7f6e\u4fe1\u7684\u8d22\u5b9d\u3002\u8d24\u8005\u4e0d\u77e5\u8bc5\u5492\u4f1a\u6301\u7eed\u591a\u4e45\u3001\u8fd8\u4f1a\u8150\u5316\u54ea\u4e9b\u751f\u7075\uff0c\u4f46\u52c7\u6562\u8005\u4ecd\u4f1a\u730e\u6740\u5b83\u4eec\u3002\u82e5\u4f60\u9047\u4e0a\u8fd9\u4e9b\u53d7\u8bc5\u4e4b\u517d\uff0c\u795d\u4f60\u597d\u8fd0\u3002",
  "s.4bf04fdbc1a20b3a": "<BR><BR>\u7b26\u6587\u888b<BR><BR>\u7b26\u6587\u888b\u4e0e\u7b26\u6587\u77f3\u8574\u542b\u529b\u91cf\uff0c\u53ef\u52a9\u65bd\u6cd5\u8005\u65e0\u9700\u8bd5\u5242\u4fbf\u65bd\u6cd5\u3002\u628a\u888b\u5b50\u653e\u5728\u80cc\u5305\u91cc\u6253\u5f00\uff0c\u518d\u9009\u62e9\u888b\u5185\u6240\u9700\u7684\u5404\u679a\u7b26\u6587\u77f3\u3002\u88c5\u5907\u888b\u5b50\u5e76\u53cc\u51fb\u5373\u53ef\u65bd\u6cd5\uff08\u524d\u63d0\u662f\u888b\u5185\u5df2\u9009\u597d\u6b63\u786e\u7b26\u6587\uff09\u3002\u8fd9\u4e9b\u888b\u5b50\u5e26\u6709\u9b54\u6cd5\u5145\u80fd\uff0c\u53ef\u7531\u6cd5\u5e08\u6536\u8d39\u5145\u586b\u3002\u6709\u4e9b\u6cd5\u672f\u9700\u8981\u8db3\u591f\u5145\u80fd\u624d\u80fd\u65bd\u5c55\u3002",
  "s.4c0badc4a677547a": "<BR><BR>",
  "s.4c91ae7432c3fa75": "\u5929\u7a7a\u57ce\u5821\u4f20\u8bf4",
  "s.4c9f1059e3544f16": "\u3010Mondain\u3011\u662f\u53e4\u738b\u3010Wolfgang\u3011\u7684\u6b21\u5b50\uff0c\u89ca\u89ce\u5144\u957f\u7ee7\u627f\u6743\uff0c\u4fbf\u4ee5\u5f3a\u5927\u529b\u91cf\u884c\u6076\u3002\u591a\u5e74\u95f4\u4ed6\u8d70\u904d\u3010Akalabeth\u3011\u4e4b\u5730\uff0c\u6240\u8fc7\u5c3d\u662f\u90aa\u6076\u4e0e\u6b7b\u4ea1\u3002\u4ed6\u5f00\u51ff\u6781\u6df1\u7684\u5730\u4e0b\u57ce\uff0c\u6700\u5e95\u5c42\u4ece\u672a\u6709\u4eba\u63a2\u5c3d\uff0c\u53c8\u5728\u5176\u4e2d\u91ca\u653e\u66f4\u591a\u90aa\u6076\uff1a\u8868\u5c42\u9644\u8fd1\u662f\u76d7\u8d3c\u3001\u9ab7\u9ac5\u4e0e\u86c7\uff0c\u6df1\u5904\u7531\u6076\u9b54\u4e0e `balrons` \u770b\u5b88\u3002\u3010Akalabeth\u3011\u8840\u6d41\u6210\u6cb3\uff0c\u79fd\u7269\u903c\u8fd1\u5730\u8868\u3002\u3010Mondain\u3011\u964d\u4e0b\u75be\u75c5\u4e0e\u761f\u75ab\uff0c\u4eba\u755c\u7686\u6d3b\u5728\u6050\u60e7\u4e2d\uff0c\u90a3\u4fbf\u662f\u3010Akalabeth\u3011\u7684\u9ed1\u6697\u65f6\u4ee3\u3002",
  "s.4f396a80f60add4d": "\u3010Tendrin Horum\u3011",
  "s.50ba8178e170df58": "\u5931\u843d\u4e4b\u5730",
  "s.5114bf34a3626ba9": "\u7070\u9f99\u6301\u6709\u8131\u56f0\u4e4b\u94a5\u3002",
  "s.51e01ced6e5f92e6": "\u8d2b\u7a77\u7684\u3010Killun\u3011",
  "s.51ef8d7232a3a869": "\u51b0\u96ea\u5973\u738b",
  "s.526979c5670b9d29": "\u6b64\u9b54\u6cd5\u53ea\u80fd\u5728\u3010Shrine of Intelligence\u3011\u91ca\u653e\u3002",
  "s.536fd0b1ccd8ad00": "\u5fb7\u9c81\u4f0a\u3010Willum\u3011",
  "s.5396f1292266d08a": "<BODY><BASEFONT Color=#e97f76>\u9000\u51fa\u6211\u7684\u672c\u5730\u884c\u4f1a</BASEFONT></BODY>",
  "s.5770002c65de330e": "\u6cd5\u5e08\u3010Erethian\u3011",
  "s.58044afffdac3eb8": "\u3010King Durmas IV\u3011\u5fa1\u524d\u6709\u4e00\u4f4d\u9ad8\u9636\u6cd5\u5e08\u8ffd\u5bfb\u6c38\u751f\u4e4b\u672f\u3002\u867d\u5949\u738b\u547d\u884c\u4e8b\uff0c\u90a3\u6cd5\u5e08\u5b9e\u5219\u60f3\u5c06\u529b\u91cf\u636e\u4e3a\u5df1\u6709\u3002\u5176\u6210\u8d25\u76f4\u5230\u6570\u4e16\u7eaa\u540e\u624d\u4e3a\u4eba\u77e5\uff1a\u4ed6\u4ece\u575f\u5893\u4e2d\u518d\u8d77\uff0c\u6b32\u7edf\u5fa1\u4e16\u95f4\u4e00\u5207\u6b7b\u8005\uff0c\u6cbf\u9014\u6740\u622e\u751f\u8005\u3002\u5728\u80fd\u5236\u670d\u8fd9\u540d\u5f3a\u5927\u5deb\u5996\u4e4b\u524d\uff0c\u4ed6\u53ea\u80fd\u6c38\u8fdc\u5c01\u5728\u3010Durmas\u3011\u5bb6\u65cf\u7684\u5893\u7a74\u91cc\u3002\u5893\u7a74\u4ec5\u6709\u4e00\u6761\u8fdb\u51fa\u4e4b\u8def\u3002\u796d\u575b\u4ee5\u5de8\u77f3\u7b51\u6210\uff0c\u7ad9\u5728\u5176\u4e0a\u5ff5\u8bf5 `xormluz` \u4fbf\u4f1a\u628a\u7ad9\u7acb\u8005\u9b54\u6cd5\u4f20\u9001\u8fdb\u5c01\u95ed\u7684\u5893\u7a74\uff1b\u53e6\u4e00\u4fa7\u796d\u575b\u4e0a\u7684\u8bcd\u53e5\u5219\u80fd\u628a\u4eba\u5e26\u56de\u3002\u7814\u7a76\u4ecd\u5728\u7ee7\u7eed\u3002",
  "s.5817f36226ca7064": "\u70bc\u91d1\u7075\u836f\u53ef\u5728\u8eab\u5fc3\u5f3a\u5316\u7684\u9886\u57df\u4e3a\u6211\u4eec\u6240\u7528\u3002\u9605\u8bfb\u672c\u4e66\u540e\uff0c\u4f60\u4fbf\u719f\u6089\u8fd9\u4e9b\u836f\u5242\uff0c\u5e76\u80fd\u5f00\u59cb\u81ea\u884c\u8c03\u914d\u3002\u4e0e\u5176\u4ed6\u70bc\u91d1\u672f\u4e00\u6837\uff0c\u4f60\u9700\u8981\u7814\u94b5\u4e0e\u6775\u3001\u5408\u9002\u7684\u8bd5\u5242\uff0c\u4ee5\u53ca\u7a7a\u74f6\u3002\u7075\u836f\u5171\u6709 49 \u79cd\uff0c\u7686\u80fd\u5728\u4e00\u5b9a\u65f6\u95f4\u5185\u63d0\u5347\u4e00\u9879\u6280\u80fd\u3002\u65e0\u6cd5\u5f3a\u5316\u7684\u53ea\u6709\u90a3\u4e9b\u672c\u8d28\u5c5e\u9b54\u6cd5\u7684\u6280\u80fd\uff0c\u4f8b\u5982 `magery`\u3001`necromancy`\u3001`ninjitsu`\u3001`bushido` \u4e0e `knightship`\u3002\u5176\u4f59\u6280\u80fd\u7686\u53ef\u7528\u7075\u836f\u5f3a\u5316\u3002<br><br>\u7075\u836f\u6548\u679c\u5f3a\u5f31\u4e0d\u4e00\uff0c\u53d6\u51b3\u4e8e\u82e5\u5e72\u56e0\u7d20\uff1a\u6709\u4e9b\u6301\u7eed\u7ea6 1 \u81f3 6 \u5206\u949f\uff0c\u6709\u4e9b\u7ea6 2 \u81f3 13 \u5206\u949f\u3002\u672c\u4e66\u5217\u51fa\u6bcf\u79cd\u7075\u836f\u53ca\u5176\u53ef\u80fd\u6301\u7eed\u65f6\u95f4\u3002<br><br>\u6301\u7eed\u65f6\u95f4\u7531\u4e09\u9879\u56e0\u7d20\u51b3\u5b9a\uff1a40% \u53d6\u51b3\u4e8e\u996e\u7528\u8005\u7684\u70f9\u996a\u6280\u827a\uff1b40% \u53d6\u51b3\u4e8e\u54c1\u5c1d\u6280\u827a\uff1b\u6700\u540e 20% \u53d6\u51b3\u4e8e\u70bc\u91d1\u6280\u827a\uff0c\u4ee5\u53ca\u996e\u7528\u8005\u662f\u5426\u6301\u6709\u4efb\u4f55\u836f\u5242\u5f3a\u5316\u5c5e\u6027\u3002\u8fd9\u4e9b\u6761\u4ef6\u8d8a\u597d\uff0c\u7075\u836f\u6301\u7eed\u8d8a\u4e45\u3002\u7075\u836f\u5f3a\u5ea6\u4ea6\u7531\u76f8\u540c\u56e0\u7d20\u51b3\u5b9a\uff0c\u5bf9\u76ee\u6807\u6280\u80fd\u7684\u52a0\u503c\u4ecb\u4e8e +10 \u81f3 +60\u3002\u540c\u4e00\u79cd\u7075\u836f\u751f\u6548\u671f\u95f4\u4e0d\u53ef\u518d\u996e\u8be5\u7c7b\u578b\u7684\u53e6\u4e00\u74f6\uff0c\u4e14\u540c\u65f6\u6700\u591a\u53ea\u80fd\u627f\u53d7\u4e24\u79cd\u7075\u836f\u6548\u679c\u3002\u4ee5\u4e0b\u662f\u5404\u7c7b\u7075\u836f\u6e05\u5355\u3002<br><br>- \u70bc\u91d1\u672f\u7075\u836f<br>    \u6301\u7eed\u7ea6 2 \u81f3 13 \u5206\u949f<br><br>- \u89e3\u5256\u5b66\u7075\u836f<br>    \u6301\u7eed\u7ea6 1 \u81f3 6 \u5206\u949f<br><br>- \u5fb7\u9c81\u4f0a\u4e4b\u9053\u7075\u836f<br>    \u6301\u7eed\u7ea6 2 \u81f3 13 \u5206\u949f<br><br>- \u6b66\u5668\u5b66\u8bc6\u7075\u836f<br>    \u6301\u7eed\u7ea6 2 \u81f3 13 \u5206\u949f<br><br>- \u4e5e\u8ba8\u7075\u836f<br>    \u6301\u7eed\u7ea6 2 \u81f3 13 \u5206\u949f<br><br>- \u953b\u9020\u7075\u836f<br>    \u6301\u7eed\u7ea6 2 \u81f3 13 \u5206\u949f<br><br>- \u949d\u51fb\u7075\u836f<br>    \u6301\u7eed\u7ea6 1 \u81f3 6 \u5206\u949f<br><br>- \u5236\u5f13\u7075\u836f<br>    \u6301\u7eed\u7ea6 2 \u81f3 13 \u5206\u949f<br><br>- \u9732\u8425\u7075\u836f<br>    \u6301\u7eed\u7ea6 2 \u81f3 13 \u5206\u949f<br><br>- \u6728\u5de5\u7075\u836f<br>    \u6301\u7eed\u7ea6 2 \u81f3 13 \u5206\u949f<br><br>- \u5236\u56fe\u7075\u836f<br>    \u6301\u7eed\u7ea6 2 \u81f3 13 \u5206\u949f<br><br>- \u70f9\u996a\u7075\u836f<br>    \u6301\u7eed\u7ea6 2 \u81f3 13 \u5206\u949f<br><br>- \u4e71\u5fc3\u7075\u836f<br>    \u6301\u7eed\u7ea6 2 \u81f3 13 \u5206\u949f<br><br>- \u523a\u5251\u7075\u836f<br>    \u6301\u7eed\u7ea6 1 \u81f3 6 \u5206\u949f<br><br>- \u5f92\u624b\u683c\u6597\u7075\u836f<br>    \u6301\u7eed\u7ea6 1 \u81f3 6 \u5206\u949f<br><br>- \u4e13\u6ce8\u7075\u836f<br>    \u6301\u7eed\u7ea6 1 \u81f3 6 \u5206\u949f<br><br>- \u9a8c\u5c38\u7075\u836f<br>    \u6301\u7eed\u7ea6 1 \u81f3 6 \u5206\u949f<br><br>- \u6cbb\u7597\u7075\u836f<br>    \u6301\u7eed\u7ea6 1 \u81f3 6 \u5206\u949f<br><br>- \u653e\u7267\u7075\u836f<br>    \u6301\u7eed\u7ea6 1 \u81f3 6 \u5206\u949f<br><br>- \u9690\u533f\u7075\u836f<br>    \u6301\u7eed\u7ea6 1 \u81f3 6 \u5206\u949f<br><br>- \u94ed\u6587\u7075\u836f<br>    \u6301\u7eed\u7ea6 2 \u81f3 13 \u5206\u949f<br><br>- \u5f00\u9501\u7075\u836f<br>    \u6301\u7eed\u7ea6 2 \u81f3 13 \u5206\u949f<