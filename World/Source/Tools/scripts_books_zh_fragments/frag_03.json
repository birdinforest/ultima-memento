{
  "s.304ab356ccab83a5": "\u3010Stranger\u3011\u8fd9\u6b21\u8981\u6551\u7684\u4e0d\u662f\u3010Sosaria\u3011\uff0c\u800c\u662f\u5730\u7403\uff0c\u5bf9\u6297\u5973\u5deb\u3010Minax\u3011\u3002\u5979\u662f\u3010Mondain\u3011\u7684\u7231\u5f92\u4e0e\u5f1f\u5b50\uff0c\u5bf9\u3010Stranger\u3011\u624b\u5203\u3010Mondain\u3011\u6781\u4e3a\u6124\u6012\uff0c\u53d1\u8a93\u590d\u4ec7\u3002\u5979\u64cd\u7eb5\u65f6\u95f4\u7ebf\uff0c\u8ba9\u5730\u7403\u5728 2111 \u5e74\u6bc1\u4e8e\u6838\u706b\u2014\u2014\u5730\u8868\u751f\u547d\u5c3d\u706d\u3002\u3010Stranger\u3011\u5728\u6700\u540e\u4e00\u523b\u9003\u8131\u65f6\u95f4\u53d8\u52a8\uff0c\u5fc5\u987b\u89e3\u5f00\u3010Time Doors\u3011\u4e4b\u8c1c\uff08\u90a3\u6247\u95e8\u80fd\u7a7f\u68ad\u65f6\u95f4\uff09\u624d\u80fd\u8d76\u5230\u3010Minax\u3011\u9762\u524d\uff0c\u963b\u6b62\u60e8\u5267\u3002\u4ed6\u53d6\u5f97\u552f\u4e00\u80fd\u6740\u6b7b\u3010Minax\u3011\u7684\u6b66\u5668\u3010Quicksword Enilno\u3011\uff0c\u6234\u4e0a\u3010Force Field Ring\u3011\u7684\u4fdd\u62a4\uff0c\u56de\u5230\u4f20\u8bf4\u65f6\u4ee3\uff0c\u5728\u57ce\u5821\u4e2d\u4e0e\u3010Minax\u3011\u5bf9\u51b3\u5e76\u5c06\u5176\u6740\u6b7b\u3002\u968f\u7740\u5979\u6b7b\u53bb\uff0c\u65f6\u95f4\u7ebf\u6062\u590d\u6b63\u5e38\uff0c\u65e0\u4eba\u8bb0\u5f97\u90a3\u6761\u88ab\u6539\u5199\u7684\u65f6\u95f4\u7ebf\u91cc\u53d1\u751f\u7684\u6050\u6016\u2026\u2026\u9664\u4e86\u3010Stranger\u3011\u4e0e\u6211\u3002",
  "s.32cf4fd03bbe51af": "\u5815\u843d\u7684\u9a91\u58eb",
  "s.334d428ba7b6a6b8": "\u65e0\u817f\u7684\u3010Girmo\u3011",
  "s.338fda253b0d183b": "\u795e\u672f\u5e08\u3010Xavier\u3011",
  "s.33aeec96a7c665df": "\u74f6\u4e2d\u57ce",
  "s.346701a1065c9440": "\u7b26\u6587\u9b54\u6cd5",
  "s.36292838810f918b": "\u8d77\u521d\u5b83\u53ea\u662f\u5929\u7a79\u4e2d\u7684\u4e00\u9897\u7403\uff0c\u6211\u4eec\u79f0\u4e4b\u4e3a\u3010Luna\u3011\u3002\u6211\u4eec\u7b49\u5f85\u65e5\u843d\u597d\u4ef0\u671b\u5b83\u3002\u3010Luna\u3011\u6309\u56fa\u5b9a\u8282\u5f8b\u51fa\u73b0\uff0c\u6211\u4eec\u5f88\u5feb\u8bb0\u4e0b\u4e86\u6708\u76f8\u53d8\u5316\uff0c\u7531\u6b64\u53d1\u73b0\u6708\u4eae\u5bf9\u3010Sosaria\u3011\u7684\u8bf8\u591a\u5f71\u54cd\u3002\u6b7b\u7075\u6cd5\u5e08\u5f97\u77e5\u6ee1\u6708\u4e4b\u65f6\u72fc\u4eba\u6700\u4e3a\u5f3a\u5927\uff1b\u672f\u58eb\u5219\u53d1\u73b0\u5404\u5730\u7684\u9b54\u6cd5\u95e8\u4f1a\u968f\u6708\u76f8\u901a\u5f80\u4e0d\u540c\u53bb\u5904\uff0c\u4e8e\u662f\u6211\u4eec\u79f0\u4e4b\u4e3a\u6708\u95e8\u3002\u6708\u4eae\u8574\u542b\u5f3a\u5927\u9b54\u529b\uff0c\u6700\u777f\u667a\u7684\u6211\u4eec\u65e5\u65e5\u805a\u96c6\uff0c\u8bd5\u56fe\u7f16\u7ec7\u8db3\u4ee5\u62b5\u8fbe\u90a3\u5929\u4f53\u7684\u6cd5\u672f\u3002<br><br>\u7ecf\u8fc7\u8fd1\u4e8c\u5341\u5e74\u7814\u7a76\uff0c\u6211\u4eec\u627e\u5230\u529e\u6cd5\uff0c\u5c06\u5355\u4e00\u6708\u95e8\u4e4b\u529b\u5c01\u5165\u4ee5\u9668\u73bb\u7483\u6240\u5236\u7684\u5c0f\u7075\u7403\u4e2d\uff0c\u4f7f\u6708\u95e8\u9b54\u529b\u88ab\u62bd\u8d70\uff0c\u5230\u5982\u4eca\u8e0f\u5165\u6708\u95e8\u8005\u82e5\u77e5\u6653\u76ee\u7684\u5730\uff0c\u4fbf\u53ef\u63a7\u5236\u53bb\u5411\u3002<br><br>\u6211\u4eec\u628a\u6355\u83b7\u7684\u9b54\u529b\u7f6e\u4e8e\u3010Shrine of Wizardry\u3011\u7684\u57fa\u5ea7\u4e0a\uff0c\u7136\u540e\u8e0f\u51fa\u767b\u6708\u7684\u7b2c\u4e00\u6b65\u3002\u90a3\u9897\u661f\u4f53\u5c0f\u800c\u7070\u3001\u5e03\u6ee1\u9668\u5751\uff0c\u5374\u8db3\u591f\u5efa\u8d77\u57ce\u5821\u4e0e\u6751\u843d\uff0c\u4e8e\u662f\u6211\u4eec\u5efa\u7acb\u4e86\u3010Dawn\u3011\u57ce\u3002<br><br>\u51ed\u501f\u5492\u672f\uff0c\u3010Luna\u3011\u5728\u7ed5\u3010Sosaria\u3011\u516c\u8f6c\u5341\u5468\u4e4b\u5185\u4fbf\u5efa\u6210\u3002\u6211\u4eec\u6709\u4e86\u5b89\u5168\u94bb\u7814\u9b54\u6cd5\u7684\u5730\u65b9\uff0c\u518d\u4e5f\u4e0d\u5fc5\u62c5\u5fc3\u6cd5\u672f\u5728\u3010Sosaria\u3011\u4e0a\u610f\u5916\u5931\u63a7\u3002<br><br>\u6211\u4eec\u66fe\u5c1d\u8bd5\u5e26\u8bbf\u5ba2\u767b\u6708\uff0c\u4f46\u6708\u9762\u529b\u91cf\u592a\u5f3a\uff0c\u9b54\u529b\u4e0d\u8db3\u8005\u4f1a\u88ab\u6392\u65a5\u3002\u4e8e\u662f\u8fd9\u91cc\u6210\u4e86\u6cd5\u5e08\u3001\u5973\u5deb\u3001\u672f\u58eb\u4e0e\u672f\u58eb\u7684\u5bb6\u56ed\u3002\u4f1a\u957f\u4eec\u5728\u9644\u8fd1\u627e\u5230\u4e00\u9897\u5c0f\u884c\u661f\uff0c\u628a\u4e3b\u884c\u4f1a\u5927\u5385\u5efa\u5728\u90a3\u91cc\uff0c\u62db\u52df\u5b66\u5f92\u5f88\u987a\u5229\uff1a\u9b54\u529b\u8584\u5f31\u8005\u53ef\u5148\u5230\u5c0f\u884c\u661f\u4fee\u4e60\uff0c\u6709\u671d\u4e00\u65e5\u518d\u767b\u6708\u81ea\u5efa\u5bb6\u56ed\u3002",
  "s.38b0e8fdb732ad42": "\u5f88\u4e45\u4ee5\u524d\u9b54\u6cd5\u4ecd\u76db\u4e4b\u65f6\uff0c\u90aa\u6076\u6cd5\u5e08\u3010Mangar the Dark\u3011\u5a01\u80c1\u540d\u53eb\u3010Skara Brae\u3011\u7684\u548c\u8c10\u5c0f\u9547\u3002\u90aa\u7269\u5728\u3010Skara Brae\u3011\u5730\u4e0b\u6e38\u8361\uff0c\u52a0\u5165\u4ed6\u7684\u9634\u5f71\u56fd\u5ea6\u3002\u3010Mangar\u3011\u4ee5\u3010Voided Death\u3011\u6cd5\u672f\u5305\u56f4\u3010Skara Brae\u3011\uff0c\u4f7f\u5176\u4e0e\u5916\u754c\u63f4\u52a9\u5f7b\u5e95\u9694\u7edd\u3002\u7136\u540e\u6709\u4e00\u591c\uff0c\u9547\u6c11\u5175\u5c3d\u6570\u6d88\u5931\uff0c\u53ea\u6709\u9547\u5185\u4e4b\u4eba\u77e5\u6653\u3002\u3010Sosaria\u3011\u5176\u4ed6\u4eba\u53ea\u89c1\u4e00\u5ea7\u6ee1\u662f\u5e9f\u589f\u7684\u5c9b\uff0c\u4ee5\u4e3a\u3010Skara Brae\u3011\u5df2\u6bc1\u2014\u2014\u8fd9\u6b63\u662f\u3010Mangar\u3011\u7684\u8ba1\u8c0b\uff0c\u8ba9\u65e0\u4eba\u524d\u6765\u53cd\u5bf9\u3002\u3010Skara Brae\u3011\u7684\u672a\u6765\u60ac\u4e8e\u4e00\u7ebf\uff0c\u518d\u65e0\u4eba\u62b5\u6297\uff0c\u53ea\u5269\u51e0\u540d\u672a\u8bd5\u950b\u8292\u7684\u5e74\u8f7b\u6218\u58eb\u3001\u521d\u51fa\u8305\u5e90\u7684\u6cd5\u5e08\u3001\u51e0\u4e4e\u521a\u5230\u996e\u9152\u5e74\u9f84\u7684\u541f\u6e38\u8bd7\u4eba\uff0c\u4ee5\u53ca\u51e0\u4e2a\u5931\u4e1a\u76d7\u8d3c\u3002\u6211\u5f53\u65f6\u5728\u573a\uff0c\u5e26\u9886\u4e00\u652f\u6742\u724c\u81ea\u7531\u519b\u3002\u6211\u4eec\u8bd5\u56fe\u51fb\u8d25\u3010Mangar\u3011\uff0c\u4f46\u4ed6\u592a\u5f3a\u3002\u6b63\u5f53\u6211\u4eec\u4ee5\u4e3a\u5f97\u624b\u65f6\uff0c\u4ed6\u5316\u4f5c\u70df\u96fe\u6d88\u5931\uff0c\u626c\u8a00\u5f52\u6765\u3002\u8fd9\u8db3\u4ee5\u524a\u5f31\u3010Voided Death\u3011\u3002\u4e00\u9053\u95e8\u77ed\u6682\u5f00\u542f\uff0c\u6211\u4eec\u7a7f\u8fc7\u95e8\u56de\u5230\u3010Sosaria\u3011\uff0c\u843d\u5728\u4e00\u5ea7\u3010Mangar\u3011\u5efa\u4e8e\u5f7c\u5904\u7684\u9ad8\u5854\u4e4b\u4e0a\u3002\u5f53\u5fc3\uff1a\u6b64\u5854\u8ba9\u3010Mangar\u3011\u80fd\u5728\u3010Skara Brae\u3011\u4e0e\u3010Sosaria\u3011\u4e4b\u95f4\u7a7f\u884c\u3002\u82e5\u4e0d\u8c28\u614e\u89e6\u78b0\u6c34\u6676\u7403\uff0c\u4fbf\u4f1a\u88ab\u56f0\u5728\u3010Skara Brae\u3011\u3002",
  "s.3901965bb62e3305": "\u591a\u79cd\u8bd5\u5242\u5377\u8f74",
  "s.3b1bef49a6c4db76": "\u53e4\u8463",
  "s.3b69b7cfa8aae03d": "\u3010Sosaria\u3011\u9700\u8981\u4e00\u4f4d\u575a\u6bc5\u82f1\u96c4\uff0c\u6562\u4e8e\u9762\u5bf9\u96be\u4ee5\u60f3\u8c61\u7684\u51f6\u9669\u3002\u761f\u75ab\u964d\u4e34\u56fd\u571f\uff0c\u707e\u7978\u6a2a\u884c\uff01\u6751\u5e84\u5316\u4e3a\u5e9f\u589f\uff0c\u66fe\u662f\u6566\u539a\u519c\u592b\u4e0e\u6e05\u9192\u5fc3\u667a\u7684\u6240\u5728\uff0c\u5982\u4eca\u53ea\u5269\u7070\u70ec\uff1b\u66fe\u662f\u9ea6\u7530\u679c\u56ed\u3001\u725b\u7f8a\u80a5\u58ee\u4e4b\u5730\uff0c\u5c3d\u6210\u8352\u829c\u3002\u79cd\u79cd\u90aa\u6076\u751f\u7269\u6355\u98df\u4eba\u6c11\u3001\u8e42\u8e8f\u571f\u5730\u3002\u8fd9\u4e00\u5207\u51fa\u81ea\u4e00\u4f4d\u6076\u540d\u8db3\u4ee5\u4ee4\u5927\u5730\u98a4\u6296\u8005\u4e4b\u624b\uff1a\u6cd5\u5e08\u3010Mondain\u3011\u628a\u6076\u6bd2\u65bd\u5c55\u5f97\u6dcb\u6f13\u5c3d\u81f4\u3002\u8d35\u65cf\u4eec\u4e92\u76f8\u653b\u8ba6\uff0c\u5404\u81ea\u9000\u56de\u57ce\u5821\uff0c\u5750\u770b\u5bf9\u624b\u503e\u8986\u3002\u90aa\u6076\u8005\u66f4\u53e0\u7978\u52a0\u7978\uff0c\u653e\u51fa\u55dc\u8840\u51f6\u6b8b\u7684\u9b54\u7269\u5927\u519b\uff0c\u65e0\u529b\u81ea\u536b\u7684\u767e\u59d3\u5982\u9ea6\u6d6a\u9047\u9570\u7eb7\u7eb7\u5012\u4e0b\u3002\u8fd9\u4e9b\u5730\u4e0b\u9b54\u7269\u51e0\u4e4e\u7edf\u6cbb\u4e86\u89c6\u91ce\u6240\u53ca\u7684\u4e00\u5207\uff0c\u53ea\u5269\u6c89\u6eba\u91ce\u5fc3\u7684\u8d35\u65cf\u8981\u585e\u3002\u6614\u65e5\u548c\u5e73\u4e61\u91ce\u518d\u65e0\u65c5\u4eba\u6562\u6c42\u5b89\u5168\u6b47\u811a\uff0c\u552f\u6709\u81ea\u5c01\u4e3a\u738b\u8005\u7684\u57ce\u5821\u53ef\u5bb9\u8eab\u2026\u2026\u4ed6\u4eec\u5374\u8981\u4ee5\u82e6\u5f79\u6362\u53d6\u65bd\u820d\u3002\u552f\u6709\u5e74\u8f7b\u7684\u3010Lord British\u3011\u4ecd\u575a\u6301\u548c\u5e73\u7edf\u4e00\u7684\u3010Sosaria\u3011\u613f\u666f\uff1b\u5728\u4ed6\u7684\u57ce\u5821\u4e0e\u57ce\u9547\u91cc\uff0c\u5fc3\u5b58\u5584\u5ff5\u8005\u80fd\u627e\u5230\u76df\u53cb\u4e0e\u8865\u7ed9\uff0c\u4ee5\u7ee7\u7eed\u4e3a\u56fd\u571f\u800c\u6218\u3002\u4ed6\u534f\u52a9\u6e05\u9664\u8fd9\u573a\u707e\u7978\uff1b\u82e5\u65e0\u4ed6\uff0c\u3010Sosaria\u3011\u5fc5\u5df2\u5728\u90aa\u574f\u6b7b\u7075\u6cd5\u5e08\u7684\u653b\u52bf\u4e0b\u706d\u4ea1\u3002",
  "s.3e707dbdbacc8e9f": "\u3010Scarlet Bard\u3011\u5730\u7a96\u4e4b\u4e0b\u6709\u4e00\u6761\u5bc6\u9053\u3002",
  "s.3e9b3329652f99dd": "\u77ee\u4eba\u66fe\u662f\u4e16\u95f4\u5927\u5320\uff0c\u4ed6\u4eec\u706d\u7edd\u4e4b\u540e\uff0c\u7cbe\u7075\u4e4b\u5730\u63a5\u8fc7\u4e86\u8fd9\u95e8\u624b\u827a\u3002\u6211\u4eec\u7cbe\u7075\u6253\u9020\u72ec\u7279\u5947\u7269\uff0c\u5e76\u4ee5\u534e\u4e3d\u8272\u5f69\u88c5\u9970\u3002\u5bf9\u7cbe\u7f8e\u5de5\u827a\u7684\u8ffd\u6c42\u4f7f\u6211\u4eec\u4e2d\u7684\u4e00\u4e9b\u4eba\u8fdc\u8d74\u5e7d\u8c37\uff0c\u6500\u5411\u6700\u9ad8\u5c71\u5cf0\uff0c\u4ee5\u4e3a\u9760\u8fd1\u8bf8\u795e\u4fbf\u80fd\u5b66\u5f97\u9020\u795e\u4e4b\u5668\u7684\u6280\u827a\u3002\u4ed6\u4eec\u6765\u5230\u3010Savaged Empire\u3011\u7684\u517d\u4eba\u9886\u5730\uff0c\u627e\u5230\u4e86\u68a6\u4e2d\u624d\u89c1\u7684\u90a3\u5ea7\u5c71\u3002\u6211\u4eec\u7684\u5144\u5f1f\u59d0\u59b9\u518d\u672a\u56de\u5230\u3010Lodoria\u3011\u7684\u4e16\u754c\uff0c\u4f46\u8bb8\u591a\u4eba\u4ecd\u60f3\u5bfb\u56de\u4ed6\u4eec\u7684\u671d\u5723\u4e4b\u8def\uff0c\u6216\u8bb8\u4e5f\u80fd\u5b66\u5230\u5929\u542f\u7684\u5de5\u827a\u3002",
  "s.3f420030e078eed3": "\u7b2c\u4e00\u9ed1\u6697\u65f6\u4ee3\u59cb\u4e8e\u6cd5\u5e08\u3010Mondain\u3011\u964d\u4e34\u3002\u3010Mondain\u3011\u4e4b\u7236\u4e0d\u80af\u628a\u6c38\u751f\u7684\u79d8\u5bc6\u4f20\u7ed9\u513f\u5b50\uff0c\u4e89\u6267\u7ec8\u81f4\u7236\u6b7b\u3002\u5728\u60b2\u75db\u4e0e\u5bf9\u8feb\u5bb3\u7684\u6050\u60e7\u9a71\u4f7f\u4e0b\uff0c\u3010Mondain\u3011\u4ee5\u9ed1\u6697\u529b\u91cf\u653b\u51fb\u3010Sosaria\u3011\u8bf8\u738b\u56fd\u3002\u5371\u6025\u4e2d\u3010Lord British\u3011\u53ec\u5524\u52c7\u58eb\u634d\u536b\u56fd\u571f\u3002\u5e94\u53ec\u800c\u6765\u7684\u82f1\u96c4\u591a\u5e74\u540e\u624d\u4ee5\u3010Stranger\u3011\u4e4b\u540d\u4e3a\u4eba\u6240\u77e5\u3002\u6b63\u662f\u8fd9\u4f4d\u3010Stranger\u3011\u51fb\u788e\u4e86\u3010Mondain\u3011\u7684\u90aa\u80fd\u5b9d\u77f3\uff0c\u3010Mondain\u3011\u672c\u4eba\u4e5f\u843d\u5f97\u53ef\u60b2\u7684\u7ec8\u5c40\u3002",
  "s.40e9def09cf68229": "\u5e73\u8861 \u5377\u4e8c\uff08\u5171\u4e8c\u5377\uff09",
  "s.43b7c75d56f02a88": "\u65e5\u5fd7",
  "s.44488675ef972f96": "\u5fb7\u9c81\u4f0a\u8349\u836f\u5b66",
  "s.47db345099883183": "\u77ee\u4eba\u81ea\u8c6a\u800c\u521a\u5f3a\uff0c\u6211\u4eec\u66fe\u628a\u3010Lodor\u3011\u7684\u8bb8\u591a\u5c71\u5cf0\u5f53\u5bb6\u3002\u773c\u89c1\u65cf\u4eba\u81ea\u5317\u5411\u5357\u88ab\u8fd9\u573a\u707e\u6b83\u541e\u566c\uff0c\u4ee4\u4eba\u5fc3\u788e\u3002\u6211\u4eec\u6b63\u5728\u6b7b\u53bb\uff0c\u6700\u5e74\u957f\u777f\u667a\u8005\u4e5f\u67e5\u4e0d\u51fa\u75c5\u56e0\u3002\u50cf\u75be\u75c5\uff0c\u8349\u836f\u5e08\u5374\u6cbb\u4e0d\u597d\uff1b\u65bd\u6cd5\u8005\u5c1d\u8bd5\uff0c\u5374\u5728\u5c1d\u8bd5\u4e2d\u6b7b\u53bb\u3002\u6211\u4eec\u53d7\u4e86\u8bc5\u5492\uff0c\u5f88\u5feb\u5c06\u4e0d\u590d\u5b58\u5728\u3002<br><br>\u8bb8\u591a\u5bb6\u56ed\u5982\u4eca\u88ab\u6076\u9b54\u6216\u4ea1\u7075\u5360\u636e\u3002\u6253\u9020\u6c0f\u65cf\u7532\u80c4\u6b66\u5668\u7684\u5320\u4eba\u90fd\u5df2\u4e0d\u5728\u3002\u53ea\u5269\u5c11\u6570\u4eba\u6324\u5728\u4e00\u8d77\uff0c\u5e0c\u671b\u9003\u8fc7\u540c\u6837\u7684\u547d\u8fd0\u3002\u6211\u66fe\u662f\u9f99\u4e3b\u2014\u2014\u5728\u7cbe\u7075\u5b66\u4f1a\u6587\u660e\u4e4b\u524d\uff0c\u8fd9\u662f\u4e00\u95e8\u7edd\u6280\u3002\u5728\u7cbe\u7075\u80fd\u9a6f\u670d\u5de8\u517d\u4e4b\u524d\uff0c\u6211\u4eec\u9f99\u4e3b\u4f1a\u5bfb\u627e\u5de8\u9f99\u6216\u5de8\u866b\u7684\u5375\uff0c\u5907\u9f50\u5b75\u5316\u6240\u9700\uff0c\u8ba9\u5e7c\u9f99\u7b2c\u4e00\u773c\u89c1\u5230\u9f99\u4e3b\u4fbf\u8ba4\u5176\u4e3a\u6bcd\uff0c\u968f\u6211\u4eec\u5f81\u6218\u4ea1\u7075\u519b\u56e2\u4e0e\u4fb5\u5165\u6211\u4eec\u7586\u57df\u7684\u9ed1\u6697\u7cbe\u7075\u3002<br><br>\u6211\u5f88\u5c0f\u5c31\u5b66\u4e60\u5fa1\u9f99\u3002\u7236\u4eb2\u4f1a\u6740\u6b7b\u5de8\u9f99\u628a\u5375\u5e26\u56de\u5bb6\u7ed9\u6bcd\u4eb2\u3002\u8981\u786e\u8ba4\u5375\u4e2d\u662f\u5426\u6709\u6d3b\u9f99\uff0c\u5fc5\u987b\u628a\u5375\u5e26\u5230\u3010Rhundar\u3011\u5c45\u6240\u7684\u7194\u5ca9\u6c60\u3002\u3010Rhundar\u3011\u66fe\u662f\u6700\u8d1f\u76db\u540d\u7684\u5de5\u5320\u4e4b\u4e61\uff0c\u6c60\u5149\u70bd\u4eae\uff0c\u80fd\u7167\u900f\u539a\u58f3\u3002\u5982\u4eca\u3010Rhundar\u3011\u5df2\u6210\u5e9f\u589f\uff0c\u6b7b\u8005\u6bc1\u5c3d\u4e00\u5207\u3002\u6211\u4eec\u53ea\u79f0\u90a3\u91cc\u4e3a\u3010Deceit\u3011\uff0c\u4ee5\u514d\u63d0\u9192\u81ea\u5df1\u5b83\u6614\u65e5\u7684\u4f1f\u5927\u3002<br><br>\u4e00\u65e6\u770b\u89c1\u6d3b\u9f99\u5728\u5375\u4e2d\uff0c\u5c31\u8981\u8c03\u914d\u56db\u5143\u7d20\u836f\u5242\u6d47\u5728\u58f3\u4e0a\uff0c\u4f7f\u58f3\u8f6f\u5316\u8ba9\u5e7c\u9f99\u7834\u51fa\u3002\u836f\u5242\u7ec4\u5408\u8ba9\u5e7c\u9f99\u51fa\u751f\u540e\u8fc5\u901f\u6210\u957f\uff0c\u7acb\u523b\u6210\u4e3a\u826f\u4f34\u3002\u6211\u66fe\u6709\u8bb8\u591a\u9f99\u5ba0\uff0c\u761f\u75ab\u5f00\u59cb\u540e\u5374\u4e0d\u80fd\u7559\u4e0b\u5b83\u4eec\u3002\u6211\u4eec\u628a\u5b83\u4eec\u653e\u8d70\uff0c\u5927\u591a\u8eb2\u8fdb\u3010Destard\u3011\u3002\u6211\u4f1a\u6000\u5ff5\u90a3\u4e9b\u65e5\u5b50\uff0c\u4e5f\u60b2\u4f24\u518d\u65e0\u5b50\u55e3\u53ef\u4f20\u6b64\u827a\u3002"
}
