  "s.083939f6e6772c50": "\u6cd5\u5e08\u3010Garamon\u3011",
  "s.0a7ed60966e85389": "\u5728\u9ed1\u6697\u541e\u6ca1\u3010King Durmas IV\u3011\u4e4b\u524d\uff0c\u4ed6\u66fe\u662f\u4e00\u4f4d\u777f\u667a\u4ec1\u539a\u7684\u541b\u4e3b\u3002\u4e16\u4eba\u591a\u5df2\u5fd8\u8bb0\u4ed6\u5f81\u4f10\u90aa\u6076\u7684\u4e8b\u8ff9\uff0c\u4ee5\u53ca\u4ed6\u7ed9\u81e3\u6c11\u5e26\u6765\u7684\u559c\u4e50\u3002\u4ed6\u70ed\u7231\u827a\u672f\u4e0e\u7f8e\uff0c\u4eca\u65e5\u4ecd\u53ef\u5728\u4ed6\u7684\u6811\u7bf1\u8ff7\u5bab\u4e2d\u7aa5\u89c1\u4e00\u6591\u3002\u738b\u9675\u4fbf\u5728\u8ff7\u5bab\u4e4b\u4e2d\uff0c\u4f46\u90aa\u6076\u5c1a\u672a\u5b8c\u5168\u6d6e\u73b0\uff0c\u672a\u80fd\u5f7b\u5e95\u73b7\u6c61\u6574\u5ea7\u8ff7\u5bab\u3002\u8ff7\u5bab\u7684\u58ee\u4e3d\u72b9\u5b58\uff0c\u4f46\u8981\u5f53\u5fc3\uff1a\u5982\u4eca\u5df2\u6709\u9b54\u7269\u7a7f\u884c\u5176\u95f4\u3002\u53d7\u8bc5\u8005\u5316\u4e3a\u725b\u5934\u4eba\u5b88\u9675\uff0c\u4e5f\u6709\u4eba\u4ecd\u6816\u8eab\u5176\u4e2d\uff0c\u501f\u4ee5\u6c42\u5f97\u4e0e\u4e16\u9694\u7edd\u7684\u6e05\u51c0\u3002\u82e5\u4f60\u8db3\u591f\u52c7\u6b66\uff0c\u503c\u5f97\u4e00\u6e38\u3002\u56fd\u738b\u5f53\u521d\u9020\u5b83\uff0c\u672c\u662f\u4e00\u6761\u6109\u60a6\u7684\u8def\u5f84\uff0c\u901a\u5f80\u4e2d\u592e\u70ed\u95f9\u7684\u9152\u9986\uff1b\u5982\u4eca\u5b83\u5374\u85cf\u7740\u4ee4\u4eba\u754f\u60e7\u7684\u5371\u9669\u4e4b\u7f8e\u3002",
  "s.0d8e0a87aeef8921": "\u722c\u884c\u52a8\u7269\u9cde\u7247\u5de5\u827a",
  "s.0dcd02eb898d4561": "\u3010Cyrus Belmont\u3011",
  "s.0fc5c4b69fb463c8": "\u6cd5\u5e08\u3010Selene\u3011",
  "s.110e7302f9fc4617": "\u3010Mondain\u3011\u4e0e\u3010Minax\u3011\u88ab\u6d88\u706d\u4e4b\u540e\uff0c\u3010Sosaria\u3011\u7684\u767e\u59d3\u4ee5\u4e3a\u6700\u574f\u7684\u5c81\u6708\u5df2\u7ecf\u8fc7\u53bb\u2026\u2026\u7136\u800c\u66f4\u7cdf\u7684\u5c1a\u5728\u540e\u5934\u3002\u3010Exodus\u3011\uff0c\u4ed6\u4eec\u7684\u5b50\u55e3\u4e0e\u9020\u7269\u2026\u2026\u65e2\u975e\u5b8c\u5168\u7684\u6076\u9b54\u4e5f\u975e\u673a\u68b0\u2026\u2026\u8981\u4e3a\u521b\u9020\u8005\u88ab\u6bc1\u800c\u590d\u4ec7\u3002\u5b83\u6380\u8d77\u6050\u6016\u5f81\u4f10\uff0c\u4ece\u6d77\u4e2d\u5347\u8d77\u4e00\u5ea7\u5c9b\u5c7f\uff0c\u53c8\u5a01\u80c1\u8981\u4ee5\u529b\u91cf\u4e0e\u90aa\u6076\u5927\u519b\u6495\u88c2\u3010Sosaria\u3011\u3002\u3010Stranger\u3011\u7b2c\u4e09\u6b21\u5f52\u6765\uff0c\u4ece\u8fd9\u65b0\u7684\u90aa\u6076\u624b\u4e2d\u62ef\u6551\u4e16\u754c\u3002\u4f46\u8fd9\u4e00\u6b21\uff0c\u82f1\u96c4\u6709\u4e09\u540d\u540c\u4f34\uff0c\u4ee5\u62b5\u6321\u3010Exodus\u3011\u7684\u90e8\u4f17\u3002\u4ed6\u4eec\u8d70\u904d\u5927\u5730\u3001\u641c\u96c6\u60c5\u62a5\uff0c\u6700\u7ec8\u5728\u5931\u843d\u4e4b\u5730\u3010Ambrosia\u3011\u627e\u5230\u56db\u5f20\u724c\u3002\u5728\u3010Time Lord\u3011\u7684\u5e2e\u52a9\u4e0b\uff0c\u4e00\u884c\u4eba\u5f97\u77e5\u51fb\u8d25\u3010Exodus\u3011\u7684\u65b9\u6cd5\u3002\u53d6\u5f97\u5f02\u57df\u6b66\u5668\u4e0e\u5f02\u57df\u62a4\u7532\u540e\uff0c\u4ed6\u4eec\u51c6\u5907\u6b63\u9762\u5bf9\u51b3\u3002\u5728\u3010Isle of Fire\u3011\u4e0a\uff0c\u4ed6\u4eec\u5148\u7ed5\u5f00\u3010Great Earth Serpent\u3011\uff0c\u4e00\u8def\u6740\u7a7f\u3010Exodus\u3011\u7684\u722a\u7259\uff0c\u7ec8\u4e8e\u62b5\u8fbe\u6838\u5fc3\u2026\u2026\u90a3\u662f\u3010Exodus\u3011\u4f5c\u4e3a\u8ba1\u7b97\u673a\u7684\u90e8\u5206\u3002\u63d2\u5165\u5361\u724c\uff0c\u673a\u5668\u7206\u70b8\uff0c\u3010Exodus\u3011\u4e0d\u590d\u5b58\u5728\u3002\u5982\u4eca\u3010Exodus\u3011\u7684\u57ce\u5821\u53ea\u5269\u5e9f\u589f\uff1b\u6562\u4e8e\u63a2\u5165\u8005\u58f0\u79f0\uff0c\u7834\u8d25\u8981\u585e\u4e4b\u4e0b\u7684\u5eca\u9053\u91cc\u4ecd\u6709\u6076\u9b54\u4e0e\u4ea1\u7075\u6e38\u8361\u3002\u4ecd\u6709\u4eba\u6562\u8fdb\u5165\uff0c\u56e0\u4e3a\u76f8\u4f20\u8d22\u5b9d\u5c31\u85cf\u5728\u90a3\u91cc\u3002",
  "s.111db11dd56828dc": "\u6211\u4ece\u3010\u4e0d\u5217\u98a0\u3011\u7684\u8d24\u8005\u5904\u5f97\u77e5\u3010Ophidian\u3011\u4e00\u65cf\u3002\u4ed6\u4eec\u4f4f\u5728\u3010Serpent Island\u3011\u4e00\u5e26\uff0c\u4fe1\u5949\u4ee5\u4e09\u86c7\u76f8\u5236\u3001\u5e73\u8861\u5b87\u5b99\u7684\u5b97\u6559\u3002\u867d\u88ab\u591a\u6570\u4eba\u89c6\u4e3a\u6c11\u4fd7\uff0c\u6211\u76f8\u4fe1\u5176\u4e2d\u81ea\u6709\u771f\u5b9e\u3002\u4ed6\u4eec\u88ab\u79f0\u4e3a\u5e73\u8861\u3001\u79e9\u5e8f\u4e0e\u6df7\u6c8c\u4e4b\u86c7\u3002\u5f53\u3010Exodus\u3011\u5c06\u5e73\u8861\u4e4b\u86c7\u4ece\u3010Serpent Island\u3011\u62d4\u53bb\u5b88\u536b\u4ed6\u7684\u57ce\u5821\u65f6\uff0c\u5e73\u8861\u5f00\u59cb\u52a8\u6447\u3002\u3010Stranger\u3011\u91ca\u653e\u4e86\u90a3\u6761\u86c7\uff0c\u4f7f\u5176\u5f97\u4ee5\u5f52\u4f4d\uff0c\u4f46\u4f59\u6ce2\u4ecd\u5728\u3002\u6df7\u6c8c\u4e0e\u79e9\u5e8f\u4ecd\u5728\u865a\u7a7a\u4e2d\u5f7c\u6b64\u4e89\u6218\uff0c\u79e9\u5e8f\u4f3c\u4e4e\u5360\u4e0a\u98ce\u3002\u6df7\u6c8c\u4e4b\u529b\u88ab\u610f\u5916\u91ca\u653e\uff0c\u9644\u5728\u4e09\u4e2a\u53ef\u601c\u7075\u9b42\u4e0a\u3002\u4ed6\u4eec\u5982\u4eca\u4ee5\u3010Chaos Banes\u3011\u4e4b\u540d\u6e38\u8361\u5728\u3010Bane\u3011\u7684\u5730\u4e0b\u57ce\u4e2d\uff0c\u6bcf\u4eba\u6301\u6709\u4e00\u6761\u7ef4\u7cfb\u5e73\u8861\u6240\u9700\u7684\u3010blackrock\u3011\u86c7\u3002\u6211\u66fe\u8bd5\u56fe\u51fb\u6740\u5176\u4e2d\u4e4b\u4e00\uff0c\u5374\u5931\u8d25\u4e86\u3002\u3010Lodor\u3011\u7684\u4e00\u540d\u5409\u666e\u8d5b\u4eba\u544a\u8bc9\u6211\uff0c\u82e5\u8981\u51fb\u8d25\u6240\u6709\u3010Chaos Banes\u3011\uff0c\u9700\u8981\u4e09\u4ef6\u72ec\u4e00\u65e0\u4e8c\u7684\u7269\u54c1\u3002\u8981\u5bf9\u4ed8\u3010Bane of Insanity\u3011\uff0c\u987b\u627e\u5230\u3010Orb of Logic\u3011\uff1b\u8981\u5bf9\u4ed8\u3010Bane of Anarchy\u3011\uff0c\u987b\u53d6\u5f97\u3010Scales of Ethicality\u3011\uff1b\u6700\u540e\u8fd8\u8981\u627e\u5230\u3010Lantern of Discipline\u3011\u624d\u80fd\u6740\u6b7b\u3010Bane of Wantoness\u3011\u3002\u8fd9\u4e9b\u7269\u54c1\u53ef\u80fd\u843d\u5728\u8bf8\u754c\u4efb\u4f55\u4e00\u5904\uff0c\u4f46\u5409\u666e\u8d5b\u4eba\u8bf4\u8981\u5728\u5730\u4e0b\u57ce\u91cc\u5bfb\u627e\u3002\u8fd9\u5c06\u662f\u4e00\u6bb5\u6f2b\u957f\u65c5\u9014\uff0c\u4f46\u82e5\u8981\u751f\u5b58\uff0c\u5e73\u8861\u5fc5\u987b\u7ef4\u6301\u3002\u6211\u8fd8\u88ab\u544a\u77e5\uff1a\u8fd9\u4e9b\u7269\u54c1\u6765\u81ea\u865a\u7a7a\uff0c\u56e0\u6b64\u6211\u82e5\u627e\u5230\u5176\u4e00\uff0c\u522b\u4eba\u4e5f\u53ef\u80fd\u4ece\u522b\u5904\u5c06\u5176\u53ec\u8d70\u3002\u6211\u5fc5\u987b\u5c3d\u5feb\u627e\u9f50\u5b83\u4eec\u5e76\u9664\u6389\u90a3\u4e9b\u3010Banes\u3011\u3002",
  "s.114764b49fdaac49": "\u3010Exodus\u3011\u7684\u6bc1\u706d",
  "s.1151192a22085575": "\u6211\u539f\u4ee5\u4e3a\u8fdc\u65b9\u53ea\u662f\u4e00\u7247\u5b64\u4e91\u3002\u4e45\u4e0d\u89c1\u96e8\u96f7\uff0c\u6211\u7684\u76ee\u5149\u4fbf\u88ab\u62c9\u5f97\u66f4\u8fdc\u3002\u90a3\u662f\u4e00\u5ea7\u57ce\u5821\uff0c\u9ad8\u60ac\u5730\u9762\u4e4b\u4e0a\u3002\u6211\u76ef\u7740\u5b83\u662f\u5426\u4f1a\u5760\u843d\uff0c\u5374\u59cb\u7ec8\u7a33\u5982\u78d0\u77f3\u3002\u6211\u51b3\u5b9a\u9760\u8fd1\uff0c\u8bbe\u6cd5\u5230\u5b83\u4e0b\u65b9\u3002\u5c31\u5728\u90a3\u65f6\uff0c\u6211\u53d1\u73b0\u4e86\u90a3\u76cf\u84dd\u8272\u9b54\u706f\u3002\u706f\u5149\u91cc\u5782\u4e0b\u4e00\u6839\u901a\u5f80\u5929\u9876\u7684\u7ef3\u7d22\u3002\u6211\u7528\u5c3d\u529b\u6c14\u6500\u7ef3\u800c\u4e0a\uff0c\u7ec8\u4e8e\u62b5\u8fbe\u4e0a\u65b9\u7684\u57ce\u5821\u3002\u6211\u6572\u51fb\u539a\u91cd\u7684\u6728\u95e8\uff0c\u56de\u58f0\u5728\u5185\u90e8\u8f70\u9e23\u3002\u7b2c\u4e09\u4e0b\u65f6\uff0c\u95e8\u88ab\u63a8\u5f00\u4e00\u9053\u7f1d\u3002\u95e8\u5f88\u96be\u5f00\uff0c\u8001\u65e7\u53d8\u5f62\uff0c\u6015\u662f\u597d\u4e9b\u5e74\u4e0d\u66fe\u5f00\u542f\u3002\u57ce\u5821\u5185\u79ef\u6ee1\u7070\u5c18\uff0c\u7a7a\u65e0\u751f\u547d\uff0c\u5385\u5802\u4e0e\u623f\u95f4\u4e5f\u6ca1\u6709\u4efb\u4f55\u8d22\u5b9d\u3002\u82e5\u6211\u6709\u9ec4\u91d1\u5e03\u7f6e\u6b64\u5730\uff0c\u6211\u4f1a\u628a\u5b83\u5f53\u5bb6\u3002\u4e0d\u77e5\u662f\u54ea\u4f4d\u6cd5\u5e08\u629b\u5f03\u4e86\u8fd9\u6837\u7684\u5c45\u6240\uff1f\u4ed6\u4eec\u662f\u5426\u66fe\u5728\u6b64\u5c45\u4f4f\u591a\u5e74\uff0c\u6700\u7ec8\u56de\u5230\u5730\u8868\u4e0e\u4f17\u4eba\u540c\u4f4f\uff1f",
  "s.119f0b0aaa61feb9": "\u76d7\u8d3c\u4e4b\u8fd0",
  "s.12bef3f6b6988446": "\u8fd0\u884c\u65f6\u95f4\uff1a",
  "s.14b0d6d77e0a8419": "\u6c34\u624b\u3010Granafla\u3011",
  "s.14b36f7bdc6547b9": "<BR><BR>\u4ee5\u4e0b\u662f\u6211\u5173\u4e8e\u7b26\u6587\u9b54\u6cd5\u3001\u5df2\u77e5\u6cd5\u672f\u4e0e\u7b26\u6587\u8bb0\u53f7\u7684\u5168\u90e8\u7814\u7a76\u3002",
  "s.15fa281902dbaeb1": "\u3010Tendrin\u3011\u7684\u65e5\u5fd7",
  "s.18fc52dbbfac2863": "\u6c34\u6676\u5251\u80fd\u5288\u5f00\u865a\u7a7a\u3002"
}
