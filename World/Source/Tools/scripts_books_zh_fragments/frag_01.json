  "s.017dcda7f5e66c90": "\u3010Underworld\u3011\u5bf9\u6211\u4eec\u6559\u56e2\u800c\u8a00\u662f\u4e00\u5904\u4e0d\u5bfb\u5e38\u4e4b\u5730\u3002\u867d\u7136\u6211\u542c\u8fc7\u6b7b\u7075\u672f\u4e0e\u795e\u5723\u9b54\u6cd5\u5728\u90a3\u6df1\u6e0a\u4e4b\u5e95\u4ecd\u80fd\u751f\u6548\u7684\u4f20\u8bf4\uff0c\u4f46\u6211\u81ea\u8eab\u7684\u6cd5\u672f\u5374\u5e38\u5e38\u5931\u7075\uff0c\u96be\u4ee5\u8bf4\u5728\u90a3\u91cc\u76f8\u5bf9\u5b89\u5168\uff1b\u8fde\u6cd5\u672f\u5377\u8f74\u4e0e\u9b54\u6756\u4e5f\u5c61\u5c61\u5931\u6548\u3002\u6816\u8eab\u5176\u4e2d\u8005\u65bd\u5c55\u6cd5\u672f\u5374\u4f3c\u4e4e\u6beb\u65e0\u963b\u788d\u3002\u82e5\u8981\u5f80\u66f4\u6df1\u5904\u8ffd\u9010\u6cf0\u5766\uff0c\u6211\u5fc5\u987b\u5904\u4e8e\u5168\u76db\u72b6\u6001\u3002\u4f20\u8bf4\u3010Codex of Ultimate Wisdom\u3011\u5728\u624b\u8005\u4fbf\u4e0d\u518d\u6709\u6b64\u7c7b\u9b54\u6cd5\u56f0\u96be\uff0c\u4f46\u90a3\u8fdc\u975e\u6211\u6240\u80fd\u53ca\uff0c\u636e\u8bf4\u5728\u3010Ethereal Void\u3011\u67d0\u5904\u3002\u6211\u7684\u4e0b\u4e00\u7ad9\u4fbf\u662f\u3010Hythloth\u3011\u7684\u5730\u4e0b\u57ce\uff0c\u636e\u6211\u7684\u7814\u7a76\uff0c\u3010Orb of the Abyss\u3011\u6b63\u5728\u90a3\u91cc\u7b49\u5f85\u3002\u6301\u6709\u6b64\u73e0\u7684\u6cd5\u5e08\u5728\u3010Underworld\u3011\u4ecd\u80fd\u65bd\u6cd5\uff1b\u4f20\u8bf4\u751a\u81f3\u8bf4\u6570\u4e16\u7eaa\u524d\u7684\u6cd5\u5e08\u5728\u8fd9\u4e9b\u6df1\u6e0a\u65bd\u5c55\u53e4\u8001\u88ab\u9057\u5fd8\u7684\u6cd5\u672f\u65f6\u4e5f\u9700\u8981\u6b64\u73e0\u3002\u7136\u800c\u73e0\u5b9d\u7531\u5927\u51f6\u770b\u5b88\u3002\u53e4\u8001\u5377\u8f74\u8bb0\u8f7d\u6709\u4e00\u9053\u95e8\u6237\u5c06\u901a\u5f80\u3010Satan\u3011\u672c\u4eba\u7684\u9886\u57df\u3002\u623f\u95f4\u636e\u8bf4\u9690\u85cf\uff0c\u4f46\u6211\u6709\u9b54\u6cd5\u80fd\u534f\u52a9\u5b9a\u4f4d\u5176\u6240\u5728\u3002\u95e8\u6237\u4e0d\u8ba9\u4efb\u4f55\u4eba\u901a\u8fc7\uff0c\u9664\u975e\u77e5\u6653\u6f5c\u4f0f\u5728\u53e6\u4e00\u4fa7\u7684\u90a3\u6076\u9b54\u7684\u771f\u540d\u3002\u5982\u679c\u90a3\u4f4d",
  "s.033db062e570ef18": "\u8fdb\u5165\u3010Mangar\u3011\u9ad8\u5854\u7684\u8def\u4e0d\u6b62\u4e00\u6761\u3002",
